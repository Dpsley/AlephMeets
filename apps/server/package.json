{
  "name": "@aleph/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/scripts/run-sql.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "db:migrate": "tsx src/scripts/run-sql.ts migration",
    "db:migrate:prod": "node dist/scripts/run-sql.js migration",
    "db:seed": "tsx src/scripts/run-sql.ts seed"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^9.1.3",
    "axios": "^1.13.2",
    "axios-ntlm": "^1.4.6",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "fast-xml-parser": "^5.3.2",
    "form-data": "^4.0.6",
    "livekit-server-sdk": "^2.14.1",
    "nanoid": "^5.1.6",
    "pg": "^8.16.3",
    "socket.io": "^4.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
