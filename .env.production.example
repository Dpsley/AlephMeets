NODE_ENV=production

# Both A records must point to the production VPS: 31.128.33.176.
API_DOMAIN=meets-api.alephtrade.com
LIVEKIT_DOMAIN=meets-livekit.alephtrade.com
API_URL=https://meets-api.alephtrade.com
VITE_TRANSCRIBE_WS_URL=wss://api.alephtrade.com/agent01/audio_transcribe_ws
LIVEKIT_URL=wss://meets-livekit.alephtrade.com

API_HOST=0.0.0.0
API_PORT=4100
MAX_UPLOAD_MB=100
UPLOAD_DIR=uploads
S3_UPLOAD_BASE_URL=https://api.alephtrade.com/s3
S3_UPLOAD_AUTH=replace-with-s3-upload-auth-token
S3_BUCKET=alephtrade-storage
S3_PUBLIC_BASE_URL=https://storage.yandexcloud.net
S3_ROOT_PATH=alephmeets

POSTGRES_USER=aleph_meets
POSTGRES_PASSWORD=replace-with-a-long-url-safe-password
POSTGRES_DB=aleph_meets
DATABASE_URL=postgresql://aleph_meets:replace-with-a-long-url-safe-password@postgres:5432/aleph_meets

LIVEKIT_API_KEY=replace-with-a-random-livekit-key
LIVEKIT_API_SECRET=replace-with-at-least-32-random-characters

IDP_BASE_URL=https://api.alephtrade.com/id
IDP_ENCODE_KEY=replace-with-service-request-encryption-key
IDP_DECODE_KEY=replace-with-service-response-decryption-key
IDP_ACCESS_KEY=replace-with-service-access-token
AD_CONTOL_SECRET=replace-with-ad-control-secret

CREDENTIAL_ENCRYPTION_KEY=replace-with-64-random-hex-characters
