{
  "name": "aleph-meets",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,desktop -c blue,magenta \"npm run dev -w @aleph/server\" \"npm run dev -w @aleph/desktop\"",
    "dev:server": "npm run dev -w @aleph/server",
    "dev:desktop": "npm run dev -w @aleph/desktop",
    "build": "npm run build -w @aleph/server && npm run build -w @aleph/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run db:migrate -w @aleph/server",
    "db:seed": "npm run db:seed -w @aleph/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
